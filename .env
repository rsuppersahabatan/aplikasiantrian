# ============================================================
# Aplikasi Antrian – Environment Variables
# ============================================================

# ── Web Server ─────────────────────────────────────────────
APP_PORT=80
APP_URL=http://localhost

# ── WebSocket Server ────────────────────────────────────────
WS_PORT=8080
WS_URL=ws://localhost

# ── Nama Container ──────────────────────────────────────────
WEB_CONTAINER_NAME=antrian_web
WS_CONTAINER_NAME=antrian_ws
